# ─────────────────────────────────────────
#  JARVIS — Environment Variables
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────

# REQUIRED — Get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — Get from https://supabase.com (free tier)
# If not set, Jarvis saves reports to local JSON files instead
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# OPTIONAL — Frontend URL for CORS (default allows localhost)
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
